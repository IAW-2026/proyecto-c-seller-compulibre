generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SellerProfile {
  clerk_user_id  String   @id
  store_name     String
  contact_email  String
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  products       Product[]
  orders         SellerOrder[]
}

model Product {
  id              String   @id @default(cuid())
  seller_id       String
  name            String
  description     String?
  category        ProductCategory
  price           Decimal  @db.Decimal(10, 2)
  brand           String
  stock           Int
  condition       ProductCondition
  images          ProductImage[]

  seller          SellerProfile @relation(fields: [seller_id], references: [clerk_user_id])
  orderItems      SellerOrderItem[]

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([name])
  @@index([category])
  @@index([brand])
  @@index([seller_id])
}

model ProductImage {
  id            String  @id @default(cuid())
  product_id    String
  image_url     String
  mime_type     String?
  original_name String?
  size          Int?
  image_data    Bytes?

  product       Product @relation(fields: [product_id], references: [id], onDelete: Cascade)
}

model SellerOrder {
  id                       String   @id @default(cuid())
  external_buyer_order_id  String
  seller_id                String
  status                   String

  seller       SellerProfile @relation(fields: [seller_id], references: [clerk_user_id])
  items        SellerOrderItem[]

  @@index([seller_id])
}

model SellerOrderItem {
  id              String @id @default(cuid())
  product_id      String
  seller_order_id String
  quantity        Int
  price           Decimal @db.Decimal(10, 2)

  product     Product     @relation(fields: [product_id], references: [id])
  order       SellerOrder @relation(fields: [seller_order_id], references: [id])
}

enum ProductCondition {
  NEW
  USED
  REFURBISHED
}

enum ProductCategory {
  CPU
  GPU
  RAM
  STORAGE
  MOTHERBOARD
  PSU
  CASE
  COOLER
  MONITOR
  PERIPHERAL
  OTHER
}
